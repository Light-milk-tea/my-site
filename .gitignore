# Dependencies
node_modules/
frontend/node_modules/
backend/node_modules/

# Build output
dist/
frontend/dist/
backend/dist/
coverage/

# Environment files
.env
.env.*
!.env.example
frontend/.env
frontend/.env.*
!frontend/.env.example
backend/.env
backend/.env.*
!backend/.env.example

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Runtime secrets, certificates, and backups
deploy/certbot/conf/*
!deploy/certbot/conf/.gitkeep
deploy/certbot/www/*
!deploy/certbot/www/.gitkeep
deploy/backups/*
!deploy/backups/.gitkeep

# OS and editor files
.DS_Store
Thumbs.db
.vscode/
.idea/
